pipeline {
    agent any

    environment {
        REGISTRY = "registry.internal"
        IMAGE_NAME = "portfolio/backend-api"
        DOCKER_TAG = "${env.BUILD_NUMBER}"
        SWARM_SERVICE_NAME = "portfolio_backend-api"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '15'))
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                dir('backend-api') {
                    sh 'npm ci'
                }
            }
        }

        stage('Test') {
            steps {
                dir('backend-api') {
                    sh 'npm run test -- --passWithNoTests'
                }
            }
        }

        stage('Build') {
            steps {
                dir('backend-api') {
                    sh 'npm run build'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('backend-api') {
                    sh "docker build -t ${REGISTRY}/${IMAGE_NAME}:${DOCKER_TAG} -t ${REGISTRY}/${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Push') {
            steps {
                echo "Pushing built image to enterprise registry..."
                // sh "docker push ${REGISTRY}/${IMAGE_NAME}:${DOCKER_TAG}"
                // sh "docker push ${REGISTRY}/${IMAGE_NAME}:latest"
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying to production Swarm or K8s..."
                // sh "docker service update --image ${REGISTRY}/${IMAGE_NAME}:${DOCKER_TAG} ${SWARM_SERVICE_NAME}"
            }
        }
    }

    post {
        failure {
            script {
                echo "Deployment failed! Initiating rollback process..."
                // sh "docker service rollback ${SWARM_SERVICE_NAME}"
            }
        }
        success {
            echo "Deployment successful."
        }
    }
}
